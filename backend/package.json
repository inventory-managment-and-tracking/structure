{
  "name": "clothtrack-backend",
  "version": "1.0.0",
  "description": "ClothTrack — Cloth Inventory Management System API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:schema": "psql -U postgres -d clothtrack -f src/db/schema.sql",
    "db:seed": "psql -U postgres -d clothtrack -f src/db/seed.sql",
    "db:migrate-roles": "node src/db/run-migrate-roles.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
